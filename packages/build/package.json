{
	"name": "@m4l-jweb/build",
	"version": "0.3.0",
	"description": "m4l-jweb: the CLI that builds and packages a device repo into installable Max for Live devices.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alienmind/m4l-jweb.git",
		"directory": "packages/build"
	},
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"m4l-jweb": "./bin/m4l-jweb.mjs"
	},
	"exports": {
		".": "./src/index.mjs",
		"./chains": "./src/chains.mjs",
		"./amxd": "./src/amxd.mjs",
		"./init": "./src/init.mjs"
	},
	"files": [
		"bin",
		"src",
		"templates",
		"LICENSE"
	],
	"dependencies": {
		"@m4l-jweb/wrapper": "workspace:*",
		"acorn": "^8.17.0",
		"archiver": "^7.0.1",
		"typescript": "^5.7.0"
	}
}
