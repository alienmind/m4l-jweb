{
	"name": "m4l-jweb",
	"private": true,
	"version": "0.5.0",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"description": "Build Ableton Live (.amxd) devices from a TypeScript repo - React UI, LiveAPI glue, CI builds, no Max editor.",
	"license": "MIT",
	"scripts": {
		"dev": "node scripts/dev.mjs hello-midi",
		"dev:hello-midi": "node scripts/dev.mjs hello-midi",
		"dev:hello-audio": "node scripts/dev.mjs hello-audio",
		"build": "tsc -b && node scripts/build-ui.mjs && m4l-jweb build",
		"build:wrapper": "m4l-jweb wrapper",
		"build:patchers": "m4l-jweb patchers",
		"install:device": "m4l-jweb install",
		"preview": "vite preview --host 127.0.0.1 --port 4175",
		"test": "vitest run",
		"format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"packages/*/src/**/*.{ts,tsx,mjs}\" \"tests/**/*.mjs\" \"patcher/*.mjs\" \"wrapper/*.ts\"",
		"release": "pnpm -r --filter=./packages/* publish --access public"
	},
	"dependencies": {
		"@m4l-jweb/bridge": "workspace:*",
		"@m4l-jweb/surface": "workspace:*",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@m4l-jweb/build": "workspace:*",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"prettier": "^3.4.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vite-plugin-singlefile": "^2.1.0",
		"vitest": "^2.1.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
