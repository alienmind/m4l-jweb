{
	"name": "m4l-jweb",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"description": "Build Ableton Live (.amxd) devices like a web developer: a React/jweb UI, a thin LiveAPI wrapper, generated patchers and a headless .amxd writer - no Max editor in the loop.",
	"scripts": {
		"dev": "vite --host 127.0.0.1 --port 5175",
		"build": "tsc -b && vite build && node scripts/build-wrapper.mjs && node scripts/generate-patchers.mjs && node scripts/postbuild.mjs",
		"build:wrapper": "node scripts/build-wrapper.mjs",
		"build:patchers": "node scripts/generate-patchers.mjs",
		"preview": "vite preview --host 127.0.0.1 --port 4175",
		"test": "vitest run",
		"format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"wrapper/**/*.ts\""
	},
	"dependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"acorn": "^8.17.0",
		"archiver": "^7.0.1",
		"@types/archiver": "^6.0.3",
		"prettier": "^3.4.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vite-plugin-singlefile": "^2.1.0",
		"vitest": "^2.1.0"
	}
}
