{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"paths": {
			"@/*": ["./src/*"],
			// vite rebinds this per build (see vite.config.ts). tsc cannot, so it
			// typechecks src/main.tsx against ONE device - which is enough, because
			// every device's app is under src/ and gets typechecked on its own anyway.
			"@device/*": ["./src/app/hello-midi/*"]
		},
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["src"]
}
